{
    "name": "amashukov/rlp-php",
    "description": "RLP (Recursive Length Prefix) encoder and decoder in pure PHP — Ethereum's canonical serialization for transactions, blocks, and state trie.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/AndreyMashukov/rlp-php",
    "keywords": ["rlp", "recursive-length-prefix", "ethereum", "evm", "serialization", "encoding", "decoding", "blockchain", "pure-php"],
    "authors": [
        {
            "name": "Andrei Mashukov",
            "email": "a.mashukoff@gmail.com",
            "homepage": "https://github.com/AndreyMashukov"
        }
    ],
    "support": {
        "issues": "https://github.com/AndreyMashukov/rlp-php/issues",
        "source": "https://github.com/AndreyMashukov/rlp-php"
    },
    "require": {
        "php": ">=8.3",
        "ext-gmp": "*"
    },
    "require-dev": {
        "amashukov/rector-php-rules": "^0.1.0",
        "friendsofphp/php-cs-fixer": "^3.50",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Amashukov\\Rlp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Amashukov\\Rlp\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse --memory-limit=512M",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "rector": "rector process --dry-run"
    }
}
